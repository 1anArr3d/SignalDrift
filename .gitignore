# --- System / IDE ---
.env
__pycache__/
*.py[cod]
*$py.class
.vscode/
.idea/

# --- Pipeline Data (Root) ---
# Keeping the output folder structure but ignoring the files inside
output/queue/*.json
output/rendered/*.mp4
output/rendered/*.mp3
output/rendered/*.ass
output/classified_posts.json
output/seen_posts.json

# --- Assets ---
# You want to keep the folders, but don't track 100MB video/audio loops
assets/backgrounds/*
assets/music/*
!assets/backgrounds/.gitkeep
!assets/music/.gitkeep

# --- Legacy Cleanup ---
# Deletes references to the old "theory farm" files
qdrant_storage/
*.csv
output/*.json
creds.json
